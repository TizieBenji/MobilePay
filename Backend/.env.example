# Copy this file to .env and fill in your values.
# NEVER commit the real .env to version control.

FLASK_DEBUG=false
PAWAPAY_ALLOW_POLLING=true

# Database
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mobilepay

# JWT
JWT_SECRET_KEY=change_me_to_a_long_random_string
# Access token lifetime in hours (defaults to 1 if unset).
JWT_ACCESS_TOKEN_EXPIRES_HOURS=1
# Refresh token lifetime in days (defaults to 30 if unset).
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# MTN MoMo (Existing direct integration)
MTN_COLLECTION_PRIMARY_KEY=
MTN_COLLECTION_SECONDARY_KEY=
MTN_DISBURSEMENT_PRIMARY_KEY=
MTN_DISBURSEMENT_SECONDARY_KEY=

# Orange (Existing direct integration)
ORANGE_CLIENT_ID=
ORANGE_CLIENT_SECRET=



# PawaPay
PAWAPAY_API_TOKEN=your_sandbox_token_here
PAWAPAY_ENVIRONMENT=sandbox     # "sandbox" or "production"

# PawaPay webhook signing secret.
# Find this in: PawaPay Dashboard → Settings → Callback URLs → Secret
# Used to verify that webhook calls actually came from PawaPay.
# REQUIRED in production. In sandbox without this set, verification is skipped
# (with a warning in logs).
PAWAPAY_WEBHOOK_SECRET=your_webhook_secret_here
